#include <iostream>
#include <thread>
#include <mutex>
#include <condition_variable>
#include <queue>
#include <chrono>
#include <vector>
#include <random>
#include <string>

// ========== 🍩 ПОНЧИКОВАЯ ==========

// Глобальные переменные
std::queue<int> donut_display;
std::mutex display_mutex;
std::condition_variable cv;
bool bakery_open = true;
bool use_mutex = true;  // Флаг: использовать ли мьютекс

// thread_local счётчик
thread_local int donuts_eaten = 0;

// ========== 🏭 ПЕКАРНЯ (PRODUCER) ==========
void bakery(int total_donuts) {
    std::random_device rd;
    std::mt19937 gen(rd());
    std::uniform_int_distribution<> bake_time(100, 300);

    std::cout << "\n🏭 ПЕКАРНЯ ОТКРЫЛАСЬ! Будет испечено " << total_donuts << " пончиков.\n" << std::endl;

    for (int i = 1; i <= total_donuts; ++i) {
        int time_to_bake = bake_time(gen);
        std::this_thread::sleep_for(std::chrono::milliseconds(time_to_bake));

        if (use_mutex) {
            // ===== РЕЖИМ С МЬЮТЕКСОМ (БЕЗОПАСНО) =====
            std::lock_guard<std::mutex> lock(display_mutex);
            donut_display.push(i);
            std::cout << "🏭 Пекарня испекла пончик #" << i << std::endl;
            std::cout << "   📦 На витрине: " << donut_display.size() << " пончиков" << std::endl;
        }
        else {
            // ===== РЕЖИМ БЕЗ МЬЮТЕКСА (ГОНКА!) =====
            donut_display.push(i);
            std::cout << "🏭 Пекарня испекла пончик #" << i << std::endl;
            std::cout << "   📦 На витрине: " << donut_display.size() << " пончиков" << std::endl;
        }

        cv.notify_one();
    }

    if (use_mutex) {
        std::lock_guard<std::mutex> lock(display_mutex);
        bakery_open = false;
    }
    else {
        bakery_open = false;
    }
    cv.notify_all();

    std::cout << "\n🏭 ПЕКАРНЯ ЗАКРЫЛАСЬ! Все " << total_donuts << " пончиков испечены.\n" << std::endl;
}

// ========== 👤 ПОКУПАТЕЛЬ (CONSUMER) ==========
void customer(int id) {
    std::random_device rd;
    std::mt19937 gen(rd());
    std::uniform_int_distribution<> eat_time(200, 800);

    std::cout << "👤 Покупатель #" << id << " зашёл в пекарню." << std::endl;

    while (true) {
        if (use_mutex) {
            // ===== РЕЖИМ С МЬЮТЕКСОМ (БЕЗОПАСНО) =====
            std::unique_lock<std::mutex> lock(display_mutex);
            cv.wait(lock, [] { return !donut_display.empty() || !bakery_open; });

            if (!donut_display.empty()) {
                int donut = donut_display.front();
                donut_display.pop();
                int remaining = donut_display.size();
                lock.unlock();

                int time_to_eat = eat_time(gen);
                std::cout << "👤 Покупатель #" << id << " взял пончик #" << donut
                    << " и ест (" << time_to_eat << " мс)..." << std::endl;
                std::this_thread::sleep_for(std::chrono::milliseconds(time_to_eat));

                ++donuts_eaten;
                std::cout << "✅ Покупатель #" << id << " СЪЕЛ пончик #" << donut
                    << " (осталось: " << remaining << ")" << std::endl;
            }
            else if (!bakery_open) {
                break;
            }
        }
        else {
            // ===== РЕЖИМ БЕЗ МЬЮТЕКСА (ГОНКА!) =====
            if (!donut_display.empty()) {
                int donut = donut_display.front();
                donut_display.pop();

                int time_to_eat = eat_time(gen);
                std::cout << "👤 Покупатель #" << id << " взял пончик #" << donut
                    << " и ест (" << time_to_eat << " мс)..." << std::endl;
                std::this_thread::sleep_for(std::chrono::milliseconds(time_to_eat));

                ++donuts_eaten;
                std::cout << "⚠️ Покупатель #" << id << " СЪЕЛ пончик #" << donut << std::endl;
            }
            else if (!bakery_open) {
                break;
            }
            else {
                // Ждём (busy wait)
                std::this_thread::sleep_for(std::chrono::milliseconds(10));
            }
        }
    }

    std::cout << "\n📊 Покупатель #" << id << " съел всего: " << donuts_eaten << " пончиков" << std::endl;
}

// ========== 🔁 ДЕМОНСТРАЦИЯ DEADLOCK С ОБЫЧНЫМ МЬЮТЕКСОМ ==========

std::mutex plain_mtx;  // Обычный мьютекс

void log_details_plain() {
    std::lock_guard<std::mutex> lock(plain_mtx);
    std::cout << "   📝 [plain] Внутренняя функция логирования" << std::endl;
}

void log_message_plain() {
    std::lock_guard<std::mutex> lock(plain_mtx);
    std::cout << "📝 [plain] Внешняя функция логирования" << std::endl;
    log_details_plain();  // 💀 Пытаемся захватить тот же мьютекс → DEADLOCK!
}

void demonstrate_deadlock() {
    std::cout << "\n========== 💀 ДЕМОНСТРАЦИЯ DEADLOCK (обычный std::mutex) ==========\n" << std::endl;
    std::cout << "Сейчас программа ЗАВИСНЕТ, потому что обычный мьютекс нельзя захватывать дважды." << std::endl;
    std::cout << "Нажмите Enter, чтобы продолжить (и увидеть зависание)...";
    std::cin.get();

    log_message_plain();  // Здесь программа зависнет

    std::cout << "Эта строка никогда не напечатается." << std::endl;
}

// ========== 🔁 ДЕМОНСТРАЦИЯ recursive_mutex ==========
std::recursive_mutex rec_mtx;

void eat_donut_half_rec() {
    std::lock_guard<std::recursive_mutex> lock(rec_mtx);
    std::cout << "    Откусили половину пончика" << std::endl;
}

void eat_whole_donut_rec() {
    std::lock_guard<std::recursive_mutex> lock(rec_mtx);
    std::cout << " Начали есть пончик:" << std::endl;
    eat_donut_half_rec();
    std::cout << "    Доели вторую половину" << std::endl;
}

void demonstrate_recursive_mutex() {
    std::cout << "\n========== ✅ ДЕМОНСТРАЦИЯ recursive_mutex ==========\n" << std::endl;
    eat_whole_donut_rec();
    std::cout << "\n✅ recursive_mutex отработал без проблем!" << std::endl;
}

// ========== 🎬 MAIN ==========
int main() {
    setlocale(LC_ALL, "Russian");

    std::cout << "╔══════════════════════════════════════════════╗" << std::endl;
    std::cout << "║         🍩 ПОНЧИКОВАЯ (Producer-Consumer)    ║" << std::endl;
    std::cout << "╚══════════════════════════════════════════════╝\n" << std::endl;

    std::cout << "Выберите режим работы:\n" << std::endl;
    std::cout << "  1 — С мьютексом (безопасно, без гонки)" << std::endl;
    std::cout << "  2 — БЕЗ мьютекса (демонстрация ГОНКИ)" << std::endl;
    std::cout << "  3 — Демонстрация DEADLOCK с обычным мьютексом" << std::endl;
    std::cout << "  4 — Демонстрация recursive_mutex (безопасно)" << std::endl;
    std::cout << "\nВаш выбор: ";

    int choice;
    std::cin >> choice;
    std::cin.ignore();  // Очищаем буфер

    if (choice == 1) {
        use_mutex = true;
        std::cout << "\n=== РЕЖИМ 1: С МЬЮТЕКСОМ (БЕЗОПАСНО) ===\n" << std::endl;
    }
    else if (choice == 2) {
        use_mutex = false;
        std::cout << "\n=== РЕЖИМ 2: БЕЗ МЬЮТЕКСА (ГОНКА!) ===\n" << std::endl;
        std::cout << "⚠️ ВНИМАНИЕ! Возможны странные результаты: пончики могут исчезнуть или съесться дважды!\n" << std::endl;
    }
    else if (choice == 3) {
        demonstrate_deadlock();
        return 0;
    }
    else if (choice == 4) {
        demonstrate_recursive_mutex();
        std::cout << "\nНажмите Enter для выхода...";
        std::cin.get();
        return 0;
    }
    else {
        std::cout << "Неверный выбор. Завершение программы." << std::endl;
        return 0;
    }

    const int total_donuts = 20;
    const int num_customers = 3;

    std::thread bakery_thread(bakery, total_donuts);

    std::vector<std::thread> customers;
    for (int i = 1; i <= num_customers; ++i) {
        customers.emplace_back(customer, i);
        std::this_thread::sleep_for(std::chrono::milliseconds(50));
    }

    bakery_thread.join();
    for (auto& c : customers) {
        c.join();
    }

    std::cout << "\n|------------------------------------------|╗" << std::endl;
    std::cout <<   "|             ПРОГРАММА ЗАВЕРШЕНА          |" << std::endl;
    std::cout <<   "|------------------------------------------|\n" << std::endl;

    // После основной части показываем recursive_mutex
    if (choice == 1 || choice == 2) {
        demonstrate_recursive_mutex();
    }

    std::cout << "\nНажмите Enter для выхода...";
    std::cin.get();
    return 0;
}
