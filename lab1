#include <iostream>
#include <thread>
#include <chrono>
#include <mutex>
#include <string>

using namespace std;

mutex cout_mutex;

// Функция для потоков
void print_task(const string& name, int delay_ms, int count) {
    for (int i = 1; i <= count; ++i) {
        {
            lock_guard<mutex> lock(cout_mutex);
            cout << "[" << name << "] -> " << i << endl;
        }
        this_thread::sleep_for(chrono::milliseconds(delay_ms));
    }
    {
        lock_guard<mutex> lock(cout_mutex);
        cout << "[" << name << "] завершён." << endl;
    }
}

// Функция для главного потока
void main_task(int count, int delay_ms) {
    for (int i = 1; i <= count; ++i) {
        {
            lock_guard<mutex> lock(cout_mutex);
            cout << "[основной поток]       итерация  " << i << endl;
        }
        this_thread::sleep_for(chrono::milliseconds(delay_ms));
    }
}

int main() {
    setlocale(LC_ALL, "Russian");

    // ========== ЧАСТЬ 1: join() ==========
    cout << "\n             #   ЧАСТЬ 1: Демонстрация join() ==========\n" << endl;

    thread t1(print_task, "Поток A", 250, 5);
    thread t2(print_task, "Поток B", 220, 5);
    //return 0;
    main_task(5, 280);

    // Ждём завершения обоих потоков
    t1.join();
    t2.join();

    cout << "\n>>> Оба потока присоединены. Программа не завершится раньше времени.\n" << endl;

    // Пауза перед второй частью
    this_thread::sleep_for(chrono::seconds(2));



    // ========== ЧАСТЬ 2: detach() ==========
    cout << "\n             #   ЧАСТЬ 2: Демонстрация detach()\n" << endl;

    thread t3(print_task, "Join-поток   t3", 200, 5);
    thread t4(print_task, "Detach-поток t4", 350, 5);

    // Отсоединяем t4
    t4.detach();
    cout << "[Главный] Поток t4 отсоединён (detach).\n" << endl;

    main_task(5, 180);

    // Ждём только t3
    t3.join();
    cout << "\n[Главный] Join-поток завершён." << endl;
    cout << "[Главный] Искусственно ждём 3 секунды, чтобы detached-поток успел закончить работу...\n" << endl;

    //            Даём detached-потоку время завершиться
    this_thread::sleep_for(chrono::seconds(3));

    cout << "\n>>> Программа завершается." << endl;

    return 0;
}
