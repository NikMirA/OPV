#include <iostream>
#include <thread>
#include <mutex>
#include <condition_variable>
#include <queue>
#include <chrono>
#include <vector>
#include <random>
#include <string>

using namespace std;

// ========== ПОНЧИКОВАЯ ==========

// Глобальные переменные
queue<int> donut_display;
mutex display_mutex;
condition_variable cv;
bool bakery_open = true;
bool use_mutex = true;  // Флаг: использовать ли мьютекс

// thread_local счётчик
thread_local int donuts_eaten = 0;

// ========== ПЕКАРНЯ (PRODUCER) ==========
void bakery(int total_donuts) {
    random_device rd;
    mt19937 gen(rd());
    uniform_int_distribution<> bake_time(100, 300);

    cout << "\n  ПЕКАРНЯ ОТКРЫЛАСЬ! Будет испечено " << total_donuts << " пончиков.\n" << endl;

    for (int i = 1; i <= total_donuts; ++i) {
        int time_to_bake = bake_time(gen);
        this_thread::sleep_for(chrono::milliseconds(time_to_bake));

        if (use_mutex) {
            // ===== РЕЖИМ С МЬЮТЕКСОМ (БЕЗОПАСНО) =====
            lock_guard<mutex> lock(display_mutex);
            donut_display.push(i);
            cout << "  Пекарня испекла пончик #" << i << endl;
            cout << "     На витрине: " << donut_display.size() << " пончиков" << endl;
        }
        else {
            // ===== РЕЖИМ БЕЗ МЬЮТЕКСА (ГОНКА!) =====
            donut_display.push(i);
            cout << "  Пекарня испекла пончик #" << i << endl;
            cout << "     На витрине: " << donut_display.size() << " пончиков" << endl;
        }

        cv.notify_one();
    }

    if (use_mutex) {
        lock_guard<mutex> lock(display_mutex);
        bakery_open = false;
    }
    else {
        bakery_open = false;
    }
    cv.notify_all();

    cout << "\n  ПЕКАРНЯ ЗАКРЫЛАСЬ! Все " << total_donuts << " пончиков испечены.\n" << endl;
}

// ========== ПОКУПАТЕЛЬ (CONSUMER) ==========
void customer(int id) {
    random_device rd;
    mt19937 gen(rd());
    uniform_int_distribution<> eat_time(200, 800);

    cout << "  Покупатель #" << id << " зашёл в пекарню." << endl;

    while (true) {
        if (use_mutex) {
            // ===== РЕЖИМ С МЬЮТЕКСОМ (БЕЗОПАСНО) =====
            unique_lock<mutex> lock(display_mutex);
            cv.wait(lock, [] { return !donut_display.empty() || !bakery_open; });

            if (!donut_display.empty()) {
                int donut = donut_display.front();
                donut_display.pop();
                int remaining = donut_display.size();
                lock.unlock();

                int time_to_eat = eat_time(gen);
                cout << "  Покупатель #" << id << " взял пончик #" << donut
                    << " и ест (" << time_to_eat << " мс)..." << endl;
                this_thread::sleep_for(chrono::milliseconds(time_to_eat));

                ++donuts_eaten;
                cout << "  Покупатель #" << id << " СЪЕЛ пончик #" << donut
                    << " (осталось: " << remaining << ")" << endl;
            }
            else if (!bakery_open) {
                break;
            }
        }
        else {
            // ===== РЕЖИМ БЕЗ МЬЮТЕКСА (ГОНКА!) =====
            if (!donut_display.empty()) {
                int donut = donut_display.front();
                donut_display.pop();

                int time_to_eat = eat_time(gen);
                cout << "  Покупатель #" << id << " взял пончик #" << donut
                    << " и ест (" << time_to_eat << " мс)..." << endl;
                this_thread::sleep_for(chrono::milliseconds(time_to_eat));

                ++donuts_eaten;
                cout << "  Покупатель #" << id << " СЪЕЛ пончик #" << donut << endl;
            }
            else if (!bakery_open) {
                break;
            }
            else {
                // Ждём (busy wait)
                this_thread::sleep_for(chrono::milliseconds(10));
            }
        }
    }

    cout << "\n  Покупатель #" << id << " съел всего: " << donuts_eaten << " пончиков" << endl;
}

// ========== ДЕМОНСТРАЦИЯ DEADLOCK С ОБЫЧНЫМ МЬЮТЕКСОМ ==========

mutex plain_mtx;  // Обычный мьютекс

void log_details_plain() {
    lock_guard<mutex> lock(plain_mtx);
    cout << "     [plain] Внутренняя функция логирования" << endl;
}

void log_message_plain() {
    lock_guard<mutex> lock(plain_mtx);
    log_details_plain();  // Пытаемся захватить тот же мьютекс → DEADLOCK!
}

void demonstrate_deadlock() {
    cout << "\n==========   ДЕМОНСТРАЦИЯ DEADLOCK (обычный std::mutex) ==========\n" << endl;
    cout << "Сейчас программа ЗАВИСНЕТ, потому что обычный мьютекс нельзя захватывать дважды." << endl;
    cout << "Нажмите Enter, чтобы продолжить (и увидеть зависание)...";
    cin.get();

    log_message_plain();  // Здесь программа зависнет

    cout << "Эта строка никогда не напечатается." << endl;
}

// ========== ДЕМОНСТРАЦИЯ recursive_mutex ==========
recursive_mutex rec_mtx;

void eat_donut_half_rec() {
    lock_guard<recursive_mutex> lock(rec_mtx);
    cout << "    Откусили половину пончика" << endl;
}

void eat_whole_donut_rec() {
    lock_guard<recursive_mutex> lock(rec_mtx);
    cout << " Начали есть пончик:" << endl;
    eat_donut_half_rec();
    cout << "    Доели вторую половину" << endl;
}

void demonstrate_recursive_mutex() {
    cout << "\n==========   ДЕМОНСТРАЦИЯ recursive_mutex ==========\n" << endl;
    eat_whole_donut_rec();
    cout << "\n  recursive_mutex отработал без проблем!" << endl;
}

// ========== MAIN ==========
int main() {
    setlocale(LC_ALL, "Russian");

    cout << "|-----------------------------------------------|" << endl;
    cout << "|            ПОНЧИКОВАЯ (Producer-Consumer)     |" << endl;
    cout << "|-----------------------------------------------|\n" << endl;

    cout << "Выберите режим работы:\n" << endl;
    cout << "  1 — С мьютексом (безопасно, без гонки)" << endl;
    cout << "  2 — БЕЗ мьютекса (демонстрация ГОНКИ)" << endl;
    cout << "  3 — Демонстрация DEADLOCK с обычным мьютексом" << endl;
    cout << "  4 — Демонстрация recursive_mutex (безопасно)" << endl;
    cout << "\nВаш выбор: ";

    int choice;
    cin >> choice;
    cin.ignore();  // Очищаем буфер

    if (choice == 1) {
        use_mutex = true;
        cout << "\n=== РЕЖИМ 1: С МЬЮТЕКСОМ (БЕЗОПАСНО) ===\n" << endl;
    }
    else if (choice == 2) {
        use_mutex = false;
        cout << "\n=== РЕЖИМ 2: БЕЗ МЬЮТЕКСА (ГОНКА!) ===\n" << endl;
        cout << "⚠️ ВНИМАНИЕ! Возможны странные результаты: пончики могут исчезнуть или съесться дважды!\n" << endl;
    }
    else if (choice == 3) {
        demonstrate_deadlock();
        return 0;
    }
    else if (choice == 4) {
        demonstrate_recursive_mutex();
        cout << "\nНажмите Enter для выхода...";
        cin.get();
        return 0;
    }
    else {
        cout << "Неверный выбор. Завершение программы." << endl;
        return 0;
    }

    const int total_donuts = 20;
    const int num_customers = 3;

    thread bakery_thread(bakery, total_donuts);

    vector<thread> customers;
    for (int i = 1; i <= num_customers; ++i) {
        customers.emplace_back(customer, i);
        this_thread::sleep_for(chrono::milliseconds(50));
    }

    bakery_thread.join();
    for (auto& c : customers) {
        c.join();
    }

    cout << "\n|------------------------------------------|╗" << endl;
    cout << "|             ПРОГРАММА ЗАВЕРШЕНА          |" << endl;
    cout << "|------------------------------------------|\n" << endl;

    cout << "\nНажмите Enter для выхода...";
    cin.get();
    return 0;
}
